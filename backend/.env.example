# Supabase Configuration
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret for verifying Supabase-issued tokens
# Get from: Supabase Dashboard > Settings > API > JWT Secret
SECRET_KEY=your-supabase-jwt-secret-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — allowed frontend origins (JSON array, no trailing slash)
CORS_ORIGINS=["http://localhost:5173"]

# Stubbed external services — fill in when ready to activate
SENDGRID_API_KEY=STUB_NOT_SET
GEMINI_API_KEY=STUB_NOT_SET

# Environment
ENVIRONMENT=development
